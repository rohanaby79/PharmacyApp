<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pharmacy Search & e-Prescription</title>
<style>
  body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: #f5f7fa;
    margin: 0;
    padding: 20px;
    color: #333;
  }

  h1, h2 {
    color: #2a7ae2;
  }

  input, button {
    padding: 10px;
    margin: 5px 0 15px 0;
    border-radius: 5px;
    border: 1px solid #ccc;
    font-size: 16px;
  }

  input:focus {
    border-color: #2a7ae2;
    outline: none;
    box-shadow: 0 0 5px rgba(42, 122, 226, 0.5);
  }

  button {
    background-color: #2a7ae2;
    color: white;
    border: none;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  button:hover {
    background-color: #1f5bb5;
  }

  form {
    background-color: white;
    padding: 20px;
    border-radius: 8px;
    box-shadow: 0 3px 8px rgba(0,0,0,0.1);
    max-width: 500px;
    margin-top: 20px;
  }

  label {
    display: block;
    margin-bottom: 10px;
  }

  ul {
    list-style: none;
    padding: 0;
  }

  li {
    background-color: white;
    margin-bottom: 10px;
    padding: 12px 15px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    gap: 10px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    transition: transform 0.1s;
  }

  li:hover {
    transform: scale(1.02);
  }

  span {
    flex: 1;
  }

  #loading {
    font-style: italic;
    color: #555;
  }
</style>
</head>
<body>

<h1>Search Pharmacies</h1>
<input type="text" id="zip" placeholder="Enter ZIP">
<input type="number" id="radius" placeholder="Radius in km" value="5">
<button onclick="searchPharmacies()">Search</button>

<ul id="results"></ul>

<h2>Create Electronic Prescription</h2>
<form id="prescriptionForm" onsubmit="submitPrescription(event)">
  <label>Medication Name: <input type="text" id="medication" required></label>
  <label>Dosage: <input type="text" id="dosage" required></label>
  <label>Frequency: <input type="text" id="frequency" required></label>
  <label>Quantity: <input type="number" id="quantity" required></label>
  <label>Patient ID: <input type="text" id="patientId" required></label>
  <label>Provider ID: <input type="text" id="providerId" required></label>
  <button type="submit">Send Prescription</button>
  <p id="loading" style="display:none;">Loading pharmacies...</p>
</form>

<script>
let selectedPharmacyId = null;

// Search pharmacies and render them safely
async function searchPharmacies() {
  const zip = document.getElementById('zip').value;
  const radius = document.getElementById('radius').value;

  const ul = document.getElementById('results');
  const loading = document.getElementById('loading');

  // Show loading
  loading.style.display = 'block';
  ul.innerHTML = '';

  try {
    const res = await fetch(`/api/pharmacies?zip=${zip}&radius=${radius}`);
    const pharmacies = await res.json();

    pharmacies.forEach(p => {
      const li = document.createElement('li');

      const radio = document.createElement('input');
      radio.type = 'radio';
      radio.name = 'selectedPharmacy';
      radio.value = p.id;
      radio.addEventListener('click', () => selectPharmacy(p.id));

      const info = document.createElement('span');
      info.innerHTML = `
        <strong>ID:</strong> ${p.id} |
        <strong>Name:</strong> ${p.name} |
        <strong>Address:</strong> ${p.address} |
        <strong>Contact:</strong> ${p.phone || "No phone"} |
        <strong>e-Prescriptions:</strong> ${p.supports_e_rx}
      `;

      li.appendChild(radio);
      li.appendChild(info);
      ul.appendChild(li);
    });

  } catch (error) {
    console.error(error);
    ul.innerHTML = '<li>Error loading pharmacies</li>';
  } finally {
    loading.style.display = 'none';
  }
}

// Set selected pharmacy ID
function selectPharmacy(id) {
  selectedPharmacyId = id;
  console.log("Selected pharmacy:", id);
}

// Submit prescription to backend
async function submitPrescription(event) {
  event.preventDefault();

  if (!selectedPharmacyId) {
    alert("Please select a pharmacy first.");
    return;
  }

  const payload = {
    pharmacy_id: selectedPharmacyId,
    medication: document.getElementById('medication').value,
    dosage: document.getElementById('dosage').value,
    frequency: document.getElementById('frequency').value,
    quantity: parseInt(document.getElementById('quantity').value),
    patient_id: document.getElementById('patientId').value,
    provider_id: document.getElementById('providerId').value
  };

  const res = await fetch('/api/prescriptions', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  });

  if (res.ok) {
    alert("Prescription sent successfully!");
    document.getElementById('prescriptionForm').reset();
  } else {
    alert("Failed to send prescription.");
  }
}
</script>
</body>
</html>